{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item for sale",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Product name"
        },
        "price": {
          "type": "number",
          "description": "Product price in dollars"
        },
        "description": {
          "type": "string",
          "description": "Product description"
        },
        "category": {
          "type": "string",
          "description": "Product category",
          "enum": ["T-Shirts", "Hoodies", "Accessories"]
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the main product image"
        },
        "sizes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available sizes"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last update"
        }
      },
      "required": ["name", "price", "description", "category", "imageUrl", "sizes", "createdAt", "updatedAt"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "Admin users",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Admin email"
        }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Contains all active product listings for the store"
    },
    "/admins/{adminId}": {
      "schema": {
        "$ref": "#/entities/AdminConfig"
      },
      "description": "Contains documents for users who have admin access"
    }
  }
}
