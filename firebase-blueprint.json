{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item for sale",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Product name"
        },
        "price": {
          "type": "number",
          "description": "Product price in dollars"
        },
        "description": {
          "type": "string",
          "description": "Product description"
        },
        "category": {
          "type": "string",
          "description": "Product category",
          "enum": ["T-Shirts", "Hoodies", "Accessories"]
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the main product image"
        },
        "sizes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available sizes"
        },
        "stock": {
          "type": "number",
          "description": "Total stock available"
        },
        "offer": {
          "$ref": "#/entities/ProductOffer",
          "description": "Any active temporary offer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last update"
        }
      },
      "required": ["name", "price", "description", "category", "imageUrl", "sizes", "stock", "stockBySize", "publishDate", "offer", "createdAt", "updatedAt"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "Admin users",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Admin email"
        }
      },
      "required": ["email"]
    },
    "ProductOffer": {
      "title": "Product Offer",
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "type": { "type": "string", "enum": ["color", "image"] },
        "value": { "type": "string" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["active", "type", "value", "endDate"]
    },
    "CartItem": {
      "title": "Cart Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "size": { "type": "string" },
        "quantity": { "type": "number" }
      },
      "required": ["id", "name", "price", "imageUrl", "size", "quantity"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/CartItem" }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific data like favorites and cart",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User verified phone number"
        },
        "shippingInfo": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zipCode": { "type": "string" },
            "country": { "type": "string" }
          },
          "required": ["fullName", "address", "city", "state", "zipCode", "country"]
        },
        "cart": {
          "type": "array",
          "items": { "$ref": "#/entities/CartItem" }
        },
        "favorites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "orders": {
          "type": "array",
          "items": { "$ref": "#/entities/Order" }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "cart", "favorites", "orders", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Contains all active product listings for the store"
    },
    "/admins/{adminId}": {
      "schema": {
        "$ref": "#/entities/AdminConfig"
      },
      "description": "Contains documents for users who have admin access"
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Contains profiles for all registered users, including their cart and favorites"
    }
  }
}
