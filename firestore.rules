rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Bootstrapped Admin: Only allow User Email from runtime or users in admins collection
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'isaacjaredmorenoflores@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Product Entity
    function isValidProductOffer(offer) {
       // if not active, type/value/endDate could be empty
       return offer.keys().hasAll(['active', 'type', 'value', 'endDate']) &&
              offer.active is bool &&
              offer.type is string && offer.type in ['color', 'image', 'none'] &&
              offer.value is string && offer.value.size() <= 2000 &&
              offer.endDate is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'description', 'category', 'imageUrl', 'sizes', 'stock', 'stockBySize', 'publishDate', 'offer', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 12 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 5000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 64 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 2000 &&
             data.sizes is list && data.sizes.size() >= 0 && data.sizes.size() <= 10 &&
             ((data.sizes.size() > 0 && data.sizes[0] is string) || data.sizes.size() == 0) &&
             data.stock is number && data.stock >= 0 &&
             data.stockBySize is map &&
             data.publishDate is string && data.publishDate.size() <= 100 &&
             isValidProductOffer(data.offer) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Products Collection
    match /products/{productId} {
      // Allow public read of products
      allow get: if isValidId(productId);
      allow list: if true; // Products are public, anyone can list them

      allow create: if isAdmin() &&
                       isValidId(productId) &&
                       isValidProduct(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;

      allow update: if isAdmin() &&
                       isValidId(productId) &&
                       isValidProduct(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'description', 'category', 'imageUrl', 'sizes', 'stock', 'stockBySize', 'publishDate', 'offer', 'updatedAt']);

      allow delete: if isAdmin() && isValidId(productId);
    }

    // Categories Collection
    function isValidCategory(data) {
       return data.keys().hasAll(['name', 'createdAt']) &&
              data.keys().size() == 2 &&
              data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
              data.createdAt is timestamp;
    }

    match /categories/{categoryId} {
       allow get, list: if true;
       allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdAt == request.time;
       allow update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
       allow delete: if isAdmin() && isValidId(categoryId);
    }

    // Admins Collection
    match /admins/{adminId} {
      allow get: if (isAdmin() || (isSignedIn() && request.auth.uid == adminId)) && isValidId(adminId);
      allow list: if isAdmin();
      
      // Allow user to upgrade themselves if they provide the secret access code
      allow create: if isSignedIn() && request.auth.uid == adminId &&
                       isValidId(adminId) && 
                       incoming().keys().hasAll(['email', 'accessCode']) &&
                       incoming().email == request.auth.token.email &&
                       incoming().accessCode == 'ADMIN_VERIFY_2026';

      allow update: if false; // Immutable
      allow delete: if isAdmin() && isValidId(adminId);
    }

    // User Profile Validation
    function isValidCartItem(item) {
      return item.keys().hasAll(['id', 'name', 'price', 'imageUrl', 'size', 'quantity']) &&
             item.id is string && item.id.size() <= 128 &&
             item.name is string && item.name.size() <= 128 &&
             item.price is number &&
             item.imageUrl is string && item.imageUrl.size() <= 500 &&
             item.size is string && item.size.size() <= 64 &&
             item.quantity is number;
    }

    function isValidFavorites(favs) {
      return favs is list && favs.size() <= 200;
    }

    function isValidCart(cart) {
      return cart is list && cart.size() <= 100 && (cart.size() == 0 || isValidCartItem(cart[0]));
    }

    function isValidOrder(order) {
       return order.keys().hasAll(['id', 'items', 'total', 'status', 'createdAt']) &&
              order.id is string &&
              order.items is list &&
              order.total is number &&
              order.status is string && order.status in ['processing', 'shipped', 'delivered'] &&
              order.createdAt is string;
    }

    function isValidOrders(ordersArg) {
      return ordersArg is list && ordersArg.size() <= 1000 && (ordersArg.size() == 0 || isValidOrder(ordersArg[0]));
    }

    function isValidShippingInfo(info) {
       return info.keys().hasAll(['fullName', 'address', 'city', 'state', 'zipCode', 'country']) &&
         info.fullName is string && info.fullName.size() <= 100 &&
         info.address is string && info.address.size() <= 200 &&
         info.city is string && info.city.size() <= 100 &&
         info.state is string && info.state.size() <= 100 &&
         info.zipCode is string && info.zipCode.size() <= 20 &&
         info.country is string && info.country.size() <= 100;
    }

    function isValidUserProfile(data) {
       return data.keys().hasAll(['email', 'cart', 'favorites', 'orders', 'createdAt']) &&
              (!data.keys().hasAny(['phoneNumber']) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
              (!data.keys().hasAny(['shippingInfo']) || (data.shippingInfo is map && isValidShippingInfo(data.shippingInfo))) &&
              data.email is string && data.email.size() <= 200 &&
              isValidCart(data.cart) &&
              isValidFavorites(data.favorites) &&
              isValidOrders(data.orders) &&
              data.createdAt is timestamp;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      
      allow create: if isSignedIn() && request.auth.uid == userId &&
                       isValidId(userId) &&
                       isValidUserProfile(incoming()) &&
                       incoming().createdAt == request.time;
                       
      allow update: if isSignedIn() && request.auth.uid == userId &&
                       isValidId(userId) &&
                       isValidUserProfile(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['cart', 'favorites', 'orders', 'phoneNumber', 'shippingInfo']);
                       
      allow delete: if false;
    }
  }
}
